<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fundocienciasnatureza"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.05" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.95" />

    <TextView
        android:id="@+id/textView2"
        android:layout_width="wrap_content"
        android:layout_height="48dp"
        android:layout_marginStart="4dp"
        android:layout_marginTop="4dp"
        android:fontFamily="sans-serif-black"
        android:text="Ciências da Natureza"
        android:textSize="35sp"
        app:layout_constraintStart_toStartOf="@+id/guideline2"
        app:layout_constraintTop_toTopOf="@+id/guideline" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="50dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="30dp"
        app:layout_constraintTop_toBottomOf="@+id/textView2"
        tools:layout_editor_absoluteX="65dp">

        <Button
            android:id="@+id/btfisica"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Física"
            android:textSize="20sp"
            android:backgroundTint="@color/cienciasnatureza"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/btquimica"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Química"
            android:textSize="20sp"
            android:backgroundTint="@color/cienciasnatureza"
            app:cornerRadius="10dp" />

        <Button
            android:id="@+id/btbiologia"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Biologia"
            android:textSize="20sp"
            android:backgroundTint="@color/cienciasnatureza"
            app:cornerRadius="10dp" />

        <LinearLayout
            android:id="@+id/menubiologia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btcitologia"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Citologia"
                android:textSize="20sp"
                android:backgroundTint="@color/cienciasnatureza"
                app:cornerRadius="10dp" />

        </LinearLayout>





    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>